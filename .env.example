# Flask
SECRET_KEY=change-this-to-random-text
APP_PASSWORD=change-this-password

# Local dev uses SQLite if DATABASE_URL is blank.
# For Supabase/Render Postgres, paste the full connection string here:
DATABASE_URL=

# OpenAI transcription
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Optional: Supabase Storage for audio files
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=audio

# Upload limit
MAX_CONTENT_MB=100
